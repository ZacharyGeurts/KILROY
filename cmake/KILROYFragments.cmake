# KILROY 1.0 — generate kernel .config fragments from CMake options + detection

function(kilroy_generate_fragments auto_fragment options_fragment)
    set(_lines "")
    string(APPEND _lines "# Auto-generated by KILROY CMake — do not edit\n")
    string(APPEND _lines "CONFIG_LOCALVERSION=\"-kilroy\"\n")
    string(APPEND _lines "CONFIG_LOCALVERSION_AUTO=n\n")
    string(APPEND _lines "CONFIG_DEFAULT_HOSTNAME=\"KILROY-Field\"\n")

    if(KILROY_ENABLE_FIELD_DIE)
        string(APPEND _lines "CONFIG_RTX_FIELD_DIE=y\n")
    endif()
    if(KILROY_ENABLE_ASM_GATE)
        string(APPEND _lines "CONFIG_RTX_FIELD_ASM_GATE=y\n")
    endif()
    if(KILROY_ENABLE_4SLOT_SECURITY)
        string(APPEND _lines "CONFIG_RTX_FIELD_4SLOT_SECURITY=y\n")
    endif()
    if(KILROY_ENABLE_FCC_GUARD)
        string(APPEND _lines "CONFIG_RTX_FIELD_FCC_GUARD=y\n")
    endif()
    if(KILROY_ENABLE_FCC_SYSCALL)
        string(APPEND _lines "CONFIG_RTX_FIELD_FCC_SYSCALL=y\n")
    endif()
    if(KILROY_ENABLE_POWER_TIERS)
        string(APPEND _lines "CONFIG_RTX_FIELD_POWER=y\n")
    endif()
    if(KILROY_ENABLE_FLOW_SLOT)
        string(APPEND _lines "CONFIG_RTX_FIELD_FLOW_SLOT=y\n")
    endif()
    if(KILROY_ENABLE_THERMO_IDLE_CREDIT)
        string(APPEND _lines "CONFIG_RTX_FIELD_THERMO_IDLE_CREDIT=y\n")
    endif()
    if(KILROY_ENABLE_ZMM_HOTPATH)
        string(APPEND _lines "CONFIG_RTX_FIELD_ZMM_HOTPATH=y\n")
    endif()
    if(KILROY_ENABLE_TESLA_BIAS)
        string(APPEND _lines "CONFIG_RTX_FIELD_TESLA_BIAS=y\n")
    endif()
    if(KILROY_ENABLE_NEXUS_GUARD)
        string(APPEND _lines "CONFIG_RTX_FIELD_NEXUS_GUARD=y\n")
    endif()
    if(KILROY_ENABLE_UTS_NAME)
        string(APPEND _lines "CONFIG_RTX_FIELD_UTS_NAME=y\n")
    endif()
    if(KILROY_ENABLE_CACHE_SLOT)
        string(APPEND _lines "CONFIG_RTX_FIELD_CACHE_SLOT=y\n")
    endif()
    if(KILROY_ENABLE_DIRECT_SLOT)
        string(APPEND _lines "CONFIG_RTX_FIELD_DIRECT_SLOT=y\n")
    endif()
    if(KILROY_ENABLE_CHARDEV)
        string(APPEND _lines "CONFIG_RTX_FIELD_CHARDEV=y\n")
    endif()
    if(KILROY_ENABLE_DRM_FCC)
        string(APPEND _lines "CONFIG_RTX_FIELD_DRM_FCC=y\n")
        string(APPEND _lines "CONFIG_PCI=y\n")
    endif()
    math(EXPR _fcc_mask "${KILROY_FCC_TOUCH_INTERVAL} - 1")
    string(APPEND _lines "CONFIG_RTX_FIELD_FCC_TOUCH_MASK=${_fcc_mask}\n")

    # CPU vendor fragments
    if(KILROY_CPU_VENDOR_DETECTED STREQUAL "INTEL")
        string(APPEND _lines "CONFIG_INTEL_IDLE=y\n")
        string(APPEND _lines "CONFIG_INTEL_PSTATE=y\n")
        string(APPEND _lines "CONFIG_INTEL_IOMMU=y\n")
    elseif(KILROY_CPU_VENDOR_DETECTED STREQUAL "AMD")
        string(APPEND _lines "CONFIG_AMD_PSTATE=y\n")
        string(APPEND _lines "CONFIG_AMD_IOMMU=y\n")
    endif()

    # GPU fragments
    if(KILROY_GPU_VENDOR_DETECTED STREQUAL "NVIDIA")
        string(APPEND _lines "CONFIG_DRM=y\n")
        string(APPEND _lines "CONFIG_DRM_NVIDIA=y\n")
    elseif(KILROY_GPU_VENDOR_DETECTED STREQUAL "AMD")
        string(APPEND _lines "CONFIG_DRM=y\n")
        string(APPEND _lines "CONFIG_DRM_AMDGPU=y\n")
    elseif(KILROY_GPU_VENDOR_DETECTED STREQUAL "INTEL")
        string(APPEND _lines "CONFIG_DRM=y\n")
        string(APPEND _lines "CONFIG_DRM_I915=y\n")
    endif()

    if(KILROY_ENABLE_PREEMPT)
        string(APPEND _lines "CONFIG_PREEMPT=y\n")
        string(APPEND _lines "CONFIG_PREEMPT_BUILD=y\n")
    endif()
    if(KILROY_ENABLE_HZ_1000)
        string(APPEND _lines "CONFIG_HZ_1000=y\n")
    endif()
    if(KILROY_ENABLE_NO_HZ_FULL AND KILROY_DETECT_CPU_CORES GREATER 4)
        string(APPEND _lines "CONFIG_NO_HZ_FULL=y\n")
    endif()

    string(APPEND _lines "CONFIG_CPU_FREQ=y\n")
    string(APPEND _lines "CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y\n")
    string(APPEND _lines "CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y\n")
    string(APPEND _lines "CONFIG_CPU_FREQ_GOV_PERFORMANCE=y\n")
    string(APPEND _lines "CONFIG_EXT4_FS=y\n")
    string(APPEND _lines "CONFIG_PROC_FS=y\n")
    string(APPEND _lines "CONFIG_BLK_DEV_NVME=y\n")
    string(APPEND _lines "CONFIG_NVME_CORE=y\n")

    file(WRITE "${auto_fragment}" "${_lines}")

    set(_opt "# KILROY menu-selected enhancements\n")
    if(KILROY_ENABLE_IO_URING)
        string(APPEND _opt "CONFIG_IO_URING=y\n")
    endif()
    if(KILROY_ENABLE_BBR)
        string(APPEND _opt "CONFIG_TCP_CONG_BBR=y\n")
    endif()
    if(KILROY_ENABLE_ZSTD)
        string(APPEND _opt "CONFIG_ZSTD_COMPRESS=y\n")
        string(APPEND _opt "CONFIG_ZSTD_DECOMPRESS=y\n")
    endif()
    if(KILROY_ENABLE_NOCACHE_FRAG)
        string(APPEND _opt "CONFIG_TRANSPARENT_HUGEPAGE=n\n")
        string(APPEND _opt "CONFIG_NUMA_BALANCING=n\n")
        string(APPEND _opt "CONFIG_SLUB_TINY=y\n")
    elseif(KILROY_ENABLE_TRANSPARENT_HUGEPAGE)
        string(APPEND _opt "CONFIG_TRANSPARENT_HUGEPAGE=y\n")
    endif()
    file(WRITE "${options_fragment}" "${_opt}")
endfunction()