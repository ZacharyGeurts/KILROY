# KILROY field-opt — fast, stable, zero-cost passthrough bias
# Applied after kilroy-identity.config on production builds

# Lighter FCC amortization (every 128 syscalls vs 32) — ~3% less guard CPU
CONFIG_RTX_FIELD_FCC_TOUCH_MASK=0x7f
CONFIG_RTX_FIELD_AI_KERNEL=y

# Scheduler stability for RTX fabric bursts
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_HZ_1000=y
CONFIG_NO_HZ_FULL=y

# I/O fast paths
CONFIG_IO_URING=y

# Security hardening (Final_Eye + NEXUS doctrine)
CONFIG_SECURITY=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y