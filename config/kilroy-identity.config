# KILROY identity — applied on top of compat substrate defconfig
CONFIG_LOCALVERSION="-kilroy"
CONFIG_LOCALVERSION_AUTO=n
CONFIG_DEFAULT_HOSTNAME="KILROY-Field"
CONFIG_RTX_FIELD_DIE=y
CONFIG_RTX_FIELD_ASM_GATE=y
CONFIG_RTX_FIELD_4SLOT_SECURITY=y
CONFIG_RTX_FIELD_FCC_GUARD=y
CONFIG_RTX_FIELD_FCC_SYSCALL=y
CONFIG_RTX_FIELD_POWER=y
CONFIG_RTX_FIELD_FLOW_SLOT=y
CONFIG_RTX_FIELD_TESLA_BIAS=y
CONFIG_RTX_FIELD_THERMO_IDLE_CREDIT=y
CONFIG_RTX_FIELD_ZMM_HOTPATH=y
CONFIG_RTX_FIELD_NEXUS_GUARD=y
CONFIG_RTX_FIELD_AI_KERNEL=y
CONFIG_RTX_FIELD_PHYSICS_BREAKTHROUGH=y
CONFIG_RTX_FIELD_HOSTESS_COMFORT=y
CONFIG_RTX_FIELD_UTS_NAME=y
CONFIG_RTX_FIELD_CACHE_SLOT=y
CONFIG_RTX_FIELD_DIRECT_SLOT=y
CONFIG_RTX_FIELD_CHARDEV=y
CONFIG_RTX_FIELD_DRM_FCC=y
CONFIG_RTX_FIELD_FCC_TOUCH_MASK=0x1f